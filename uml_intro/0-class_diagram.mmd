classDiagram
    class Library {
        +add_book()
        +register_user()
        +create_loan()
    }
    class User {
        +name: str
        +email: str
    }
    class Book {
        +title: str
        +author: str
        +state: bool
        +mark_as_available()
        +mark_as_unavailable()
    }
    class Loan {
        +start_date: str
        +end_date: str
        +close_loan()
    }

    Library "1" o-- "0..*" Book
    Library "1" o-- "0..*" User
    Library ..> Loan
    Loan "1" --> "1" Book
    Loan "*" --> "1" User